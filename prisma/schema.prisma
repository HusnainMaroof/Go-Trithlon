generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum Discipline {
  SWIMMER
  CYCLIST
  RUNNER
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CompetitionLevel {
  NONE
  LOCAL
  NATIONAL
  PROFESSIONAL
}

enum TeamStatus {
  OPEN
  COMPLETE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  REVOKED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  name       String?
  status     UserStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  userToken  String?    @unique
  google_id  String?    @unique
  is_Onboard Boolean    @default(false)
  inTeam Boolean    @default(false)
profileImage              String?   
  athleteProfile  AthleteProfile?
ownedTeams MyTeam[] @relation("TeamOwner")
  teamMemberships MyTeamMember[]
  sentInvites     TeamInvite[]   @relation("InviteSender")
  receivedInvites TeamInvite[]   @relation("InviteReceiver")
  
}

model AthleteProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  locationCity String?

  disciplines Discipline[]

  // performance per discipline (only relevant ones filled)
  swimTime100m  Float?
  cycleTime10km Float?
  runTime5km    Float?

  experienceLevel     ExperienceLevel
  trainingDaysPerWeek Int?
  competitionLevel    CompetitionLevel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MyTeam {
  id        String     @id @default(uuid())
  name      String
  ownerId   String
owner User @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  status    TeamStatus @default(OPEN)

  members   MyTeamMember[]
  invites   TeamInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MyTeamMember {
  id       String     @id @default(uuid())

  teamId   String
  team     MyTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId   String
user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ✅ ONE row = ONE role
  // same user can have TWO rows (two roles) in same team
  role     Discipline

  joinedAt DateTime   @default(now())

  // ✅ one role slot per team — prevents duplicate role
  // userId NOT in unique → allows same user in multiple roles
  @@unique([teamId, role])
}

model TeamInvite {
  id         String       @id @default(uuid())

  teamId     String
  team       MyTeam       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  fromUserId String
  fromUser   User         @relation("InviteSender", fields: [fromUserId], references: [id], onDelete: Cascade)

  toUserId   String
  toUser     User         @relation("InviteReceiver", fields: [toUserId], references: [id], onDelete: Cascade)

  role       Discipline
  status     InviteStatus @default(PENDING)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt


  @@unique([teamId, toUserId, role])
  
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

