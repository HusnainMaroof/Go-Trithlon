generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum Discipline {
  SWIMMER
  CYCLIST
  RUNNER
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CompetitionLevel {
  NONE
  LOCAL
  NATIONAL
  PROFESSIONAL
}

enum TeamStatus {
  OPEN
  COMPLETE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  REVOKED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  name          String?
  status        UserStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userToken     String?    @unique
  google_id     String?    @unique
  is_Onboard    Boolean    @default(false)
  inTeam        Boolean    @default(false)
  profileImage  String?

  athleteProfile  AthleteProfile?
  ownedTeams      MyTeam[]       @relation("TeamOwner")
  teamMemberships MyTeamMember[]
  sentInvites     TeamInvite[]   @relation("InviteSender")
  receivedInvites TeamInvite[]   @relation("InviteReceiver")
}

model AthleteProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName  String?
  locationCity String?

  disciplines  Discipline[]

  // kept for future use — not collected in onboarding v2

  trainingDaysPerWeek Int?
  competitionLevel    CompetitionLevel?

  experienceLevel ExperienceLevel

  // new relations
  raceResults  RaceResult[]
  achievements Achievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Stores one best time per discipline+distance per athlete.
// Multiple rows allowed (e.g. two different marathon entries in future).
model RaceResult {
  id         String         @id @default(uuid())
  profileId  String
  profile    AthleteProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  discipline Discipline
  distance   String     // "5K" | "10K" | "Half Marathon" | "Full Marathon" | "750m" | "1500m" | "5K Open Water" | "20K" | "40K" | "90K" | "180K"
  timeSeconds Float     // always stored in seconds, formatted for display

  createdAt  DateTime   @default(now())

  @@index([profileId])
}

// Free-form athlete achievements — separate from race results.
model Achievement {
  id          String         @id @default(uuid())
  profileId   String
  profile     AthleteProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title       String
  description String?

  createdAt   DateTime       @default(now())

  @@index([profileId])
}

model MyTeam {
  id        String     @id @default(uuid())
  name      String
  ownerId   String
  owner     User       @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  status    TeamStatus @default(OPEN)

  members   MyTeamMember[]
  invites   TeamInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MyTeamMember {
  id       String     @id @default(uuid())

  teamId   String
  team     MyTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     Discipline

  joinedAt DateTime   @default(now())

  @@unique([teamId, role])
}

model TeamInvite {
  id         String       @id @default(uuid())

  teamId     String
  team       MyTeam       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  fromUserId String
  fromUser   User         @relation("InviteSender", fields: [fromUserId], references: [id], onDelete: Cascade)

  toUserId   String
  toUser     User         @relation("InviteReceiver", fields: [toUserId], references: [id], onDelete: Cascade)

  role       Discipline
  status     InviteStatus @default(PENDING)
  isRead     Boolean      @default(false)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([teamId, toUserId, role])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}
